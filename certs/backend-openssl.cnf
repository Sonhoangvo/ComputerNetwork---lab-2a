[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
req_extensions     = req_ext
distinguished_name = dn

[ dn ]
C  = VN
ST = HCMC
L  = HCMC
O  = GroupX Lab
OU = Backends
CN = backend_pool

[ req_ext ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = backend_pool
DNS.2 = backend-a
DNS.3 = backend-b
DNS.4 = backend-a.backend
DNS.5 = backend-b.backend
